{
  "name": "vmetrix",
  "version": "1.0.0",
  "private": true,
  "description": "VMetrix QA Automation Challenge - Playwright + TypeScript with POM, Allure reports",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:headed": "playwright test tests/ui --headed",
    "report": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "report:generate": "allure generate allure-results --clean -o allure-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "allure-playwright": "^3.0.0",
    "allure-commandline": "^2.30.0",
    "typescript": "^5.8.3",
    "@types/node": "^22.15.21"
  }
}
